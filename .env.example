# AgentRanks Core — Environment Variables
# Copy this file to .env and fill in your values.

# ─── LLM Configuration ────────────────────────────────────────────────────────
# OpenAI-compatible API key (required for agentranks extract)
AGENTRANKS_LLM_API_KEY=your-api-key-here

# LLM base URL — defaults to DeepSeek. Set this for OpenAI or other compatible providers.
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:   https://api.openai.com/v1
# Local:    http://localhost:11434/v1  (Ollama)
AGENTRANKS_LLM_BASE_URL=https://api.deepseek.com/v1

# Model name
# Recommended (high quality): deepseek-v4-pro
# Recommended (low cost):     deepseek-v4-flash
# Legacy (deprecated):        deepseek-chat  (maps to v4-flash compatibility)
AGENTRANKS_LLM_MODEL=deepseek-v4-pro

# Maximum output tokens (optional — omit to let the model use its own maximum)
# Only set this if you need to cap cost or the API requires an explicit limit.
# AGENTRANKS_LLM_MAX_TOKENS=8192

# ─── Crawler Configuration ────────────────────────────────────────────────────
# Maximum pages to crawl per run (default: 50)
AGENTRANKS_MAX_PAGES=50

# Delay between requests in milliseconds (default: 500)
AGENTRANKS_CRAWL_DELAY=500
